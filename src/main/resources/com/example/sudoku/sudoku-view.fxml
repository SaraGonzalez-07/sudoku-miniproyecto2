<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<HBox alignment="CENTER" spacing="40" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sudoku.controller.SudokuController">
    <children>

        <VBox alignment="CENTER" spacing="0" prefWidth="250">
            <children>
                <StackPane styleClass="dialog-bubble" minHeight="100">
                    <Label fx:id="messageLabel" text="Hola, ¿Listo para jugar?" wrapText="true" styleClass="kentin-text" />
                </StackPane>

                <ImageView fitHeight="380.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@kentin.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>

        <VBox alignment="CENTER" spacing="25">
            <Label styleClass="title" text="Sudoku" />

            <GridPane fx:id="sudokuGrid" alignment="CENTER" styleClass="grid-pane">
            </GridPane>

            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#handleHelp" styleClass="button-help" text="Ayuda" />
                <Button onAction="#handleNewGame" styleClass="button-generic" text="Nuevo Juego" />
            </HBox>
        </VBox>

    </children>
</HBox>